# storm-codex-server — config (copier en .env, non commité). Dev = Postgres Docker (5433).
DATABASE_URL=postgres://storm:storm@localhost:5433/storm_codex
BIND_ADDR=127.0.0.1:8088
# Archive des replays bruts (source de vérité — 3 étages de données)
ARCHIVE_DIR=./.archive
# Cache LRU des dumps décodés à la demande (jalon 3 T7)
RAW_CACHE_DIR=./.raw-cache
RAW_CACHE_MAX_BYTES=5368709120
# Jeton admin (endpoints /api/admin). VIDE ou absent = mode ouvert, aucune auth (auto-hébergement
# local LAN/Tailscale). Le définir réactive l'auth Bearer (recommandé si exposé publiquement).
ADMIN_TOKEN=
# Référentiel héros/talents — API HotsPatchNotes (setup mainteneur). En bundle, laisse vide et
# utilise plutôt REFERENTIAL_URL (snapshot publié).
HOTSPATCHNOTES_URL=http://localhost:5001
# Jarvis (Redis) + Twitch Azure
REDIS_URL=redis://127.0.0.1:6380
JARVIS_CHANNEL=jarvis:events
# AZURE_PUSH_URL=
# AZURE_PUSH_TOKEN=
