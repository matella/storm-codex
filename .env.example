# storm-codex-server — config (copier en .env, non commité). Dev = Postgres Docker (5433).
DATABASE_URL=postgres://storm:storm@localhost:5433/storm_codex
BIND_ADDR=127.0.0.1:8088
# Archive des replays bruts (source de vérité — 3 étages de données)
ARCHIVE_DIR=./.archive
# Cache LRU des dumps décodés à la demande (jalon 3 T7)
RAW_CACHE_DIR=./.raw-cache
RAW_CACHE_MAX_BYTES=5368709120
# Jeton admin (endpoints /api/admin)
ADMIN_TOKEN=dev-admin-token
