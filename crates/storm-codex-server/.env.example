# storm-codex-server — configuration (toutes les variables par env, serveur stateless / V2-ready).
# Copier en .env pour le dev local (non commité). En prod box : valeurs dans le .env du box.

# ── Obligatoire ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://storm:storm@localhost:5433/storm_codex   # dev : docker-compose.dev.yml

# ── Réseau / front ───────────────────────────────────────────────────────────
BIND_ADDR=127.0.0.1:8088          # prod conteneur : 0.0.0.0:8088
WEB_DIR=                          # chemin du SPA buildé (web/dist) ; vide = API seule

# ── Stockage (3 étages de données) ───────────────────────────────────────────
ARCHIVE_DIR=./.archive            # replays bruts = source de vérité (ne pas purger)
RAW_CACHE_DIR=./.raw-cache        # cache LRU des dumps décodés à la demande
RAW_CACHE_MAX_BYTES=5368709120    # 5 GiB

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=dev-admin-token       # protège /api/admin/* et la gestion équipes/collections

# ── Référentiel héros/talents (lecture seule) ────────────────────────────────
HOTSPATCHNOTES_URL=http://localhost:5001   # répliqué dans dim_* au démarrage ; absent = skip

# ── Push opt-in (renseignés à la bascule jalon 5 — cf. runbook) ──────────────
REDIS_URL=                        # Redis Jarvis : émet hots.match.completed ; absent = pas d'émission
JARVIS_CHANNEL=jarvis:events
AZURE_PUSH_URL=                   # EBS Twitch Azure : push post-game sortant ; absent = pas de push
AZURE_PUSH_TOKEN=
